<!DOCTYPE html>
<html>
    <head>
        <title>{{ title }}</title>
        <meta name="viewport" content="minimum-scale=1, initial-scale=1, width=device-width">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@700&display=swap" rel="stylesheet">
        <style>
            body {
                margin: 0;
                padding: 0;
                font-family: 'Roboto Condensed', sans-serif;
            }

            main {
                width: 320px;
                margin: auto;
                margin-top: 20px;
            }

            #heading-image {
                width: 100%;
                padding: 10px;
            }

            #heading-image img {
                max-width: calc(100% - 20px);
            }

            #heading-title {
                padding: 10px;
                text-align: right;
            }

            #heading-title-track {
                font-size: 24px;
            }

            #heading-title-version {
                font-size: 12px;
                margin-top: 6px;
            }

            #selection-info {
                font-size: 12px;
                text-align: center;
                margin: 20px 0;
                border-bottom: 1px solid;
                padding-bottom: 5px;
            }

            .listen-link {
                margin: 10px 0;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .listen-link img {
                height: 60px;
            }

            .listen-button {
                padding: 10px;
                background-color: aliceblue;
                cursor: pointer;
                text-decoration: none;
            }
        </style>
    </head>
    <body>
        <main>
            {{ content | safe }}
        </main>
    </body>
</html>

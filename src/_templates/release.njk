---
pagination:
  data: releasePages
  size: 1
  alias: release
permalink: "/{{ release.slug }}/"
layout: base.njk
eleventyComputed:
  title: "TrajDali - {{ release.title }}"
---

<heading>
    <div id="heading-image">
        <img src="/{{ release.headerImage }}" alt="TrajDali - {{ release.title }}" />
    </div>
    <div id="heading-logo">
        <img src="/logo-black.png" alt="TrajDali Logo" />
    </div>
</heading>

{% if release.links %}
<section id="additional-links">
    <h2 class="section-heading">Additional links</h2>
    {% for link in release.links %}
    <a href="{{ link.url }}" class="view-all-link">{{ link.label }}</a>
    {% endfor %}
</section>
{% endif %}

<section id="end-of-the-page-room"></section>

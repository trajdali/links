---
pagination:
  data: mixes
  size: 1
  alias: mix
permalink: "/{{ mix.slug }}/"
layout: base.njk
eleventyComputed:
  title: "TrajDali - {{ mix.title }}"
---

<heading>
    <div id="heading-image">
        <img src="/background.jpg" alt="Heading Image" />
    </div>
    <div id="heading-logo">
        <img src="/logo-black.png" alt="TrajDali Logo" />
    </div>
</heading>

<section id="mix-section">
    <h2 class="section-heading">{{ mix.title }}</h2>
    <iframe class="mix-embed" src="https://www.youtube.com/embed/{{ mix.youtubeId }}?controls=0" title="TrajDali - {{ mix.title }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
</section>

{% if mix.tracklist %}
<section id="tracklist">
    <h2 class="section-heading">Tracklist</h2>
    <ol>
        {% for track in mix.tracklist %}
        <li>{{ track }}</li>
        {% endfor %}
    </ol>
</section>
{% endif %}

{% if mix.links %}
<section id="additional-links">
    <h2 class="section-heading">Additional links</h2>
    {% for link in mix.links %}
    <a href="{{ link.url }}" class="view-all-link">{{ link.label }}</a>
    {% endfor %}
</section>
{% endif %}

<section id="end-of-the-page-room"></section>
